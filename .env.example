# ==============================================================================
# SIEM Analytics Platform - Environment Configuration Template
# Copy this file to '.env' at the repository root to override default settings.
# ==============================================================================

# Database Engine Selection
# Set to 'true' for zero-config local SQLite (backend/siem.db), or 'false' for PostgreSQL
USE_SQLITE=true

# PostgreSQL Configuration (used when USE_SQLITE=false)
POSTGRES_USER=siem_admin
POSTGRES_PASSWORD=siem_secure_2024
POSTGRES_DB=siem_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Redis Cache & Message Broker
REDIS_URL=redis://localhost:6379/0

# JWT Authentication
# IMPORTANT: Change JWT_SECRET to a strong random key in production deployments!
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=480

# Backend Server Settings
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
DEBUG=true
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
